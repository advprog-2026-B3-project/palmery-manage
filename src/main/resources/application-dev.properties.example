# ============================================================
# TEMPLATE KONFIGURASI LOKAL DEVELOPER
# ============================================================
# CARA PAKAI:
# 1. Salin file ini: cp application-dev.properties.example application-dev.properties
# 2. Edit application-dev.properties sesuai pengaturan database lokal Anda
# 3. JANGAN commit application-dev.properties ke Git (sudah ada di .gitignore)
# ============================================================

# --- Database Lokal ---
# Pilihan A: PostgreSQL Docker (port 5433)
spring.datasource.url=jdbc:postgresql://localhost:5433/managedb
spring.datasource.username=postgres
spring.datasource.password=postgres

# Pilihan B: PostgreSQL lokal laptop (port 5432) — sesuaikan nama DB & password
# spring.datasource.url=jdbc:postgresql://localhost:5432/palmery_manage_dev
# spring.datasource.username=postgres
# spring.datasource.password=your_local_password_here

# --- Flyway (Migrasi DB) ---
spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration

# --- JPA ---
spring.jpa.show-sql=true
spring.jpa.hibernate.ddl-auto=none

# --- Logging (opsional, aktifkan jika perlu debug) ---
logging.level.id.ac.ui.cs.advprog.palmerymanage=DEBUG
# logging.level.org.springframework.cache=TRACE
# logging.level.io.lettuce=DEBUG
